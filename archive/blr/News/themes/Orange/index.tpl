  
<table border="0" cellpadding="0" cellspacing="0" width="100%">
  <tr> 
    <td valign="top" align="left" width="1%" background="{url}/themes/Orange/leftt.gif"> 
      <p><img border="0" src="{path}/themes/Orange/topleft.gif"> 
    </td>
    <center>
      <td width="98%" background="{path}/themes/Orange/top.gif" colspan="2"><b><font face="Verdana" color="#FFFFFF">&gt; 
        {subject}</font></b></td>
    </center>
    <td width="1%" valign="top" align="right" background="{url}/themes/Orange/leftt.gif"><img border="0" src="{path}/themes/Orange/topright.gif"></td>
  </tr>
  <center>
    <tr> 
      <td width="1%" background="{path}/themes/Orange/left.gif" style="border-left: 1 solid #000000">&nbsp;</td>
      <td bgcolor="#FFFFFF" colspan="2"><font color="#000000" face="Verdana" size="1"><br>
        &nbsp;{news}<br>
        &nbsp;</font></td>
      <td width="1%" style="border-right: 1 solid #000000" background="{url}/themes/Orange/left.gif">&nbsp;</td>
    </tr>
  </center>
  <tr> 
    <center>
      <td width="1%" valign="bottom" background="{url}/themes/Orange/leftb.gif"><img border="0" src="{url}/themes/Orange/botleft.gif"></td>
    </center>
    <td width="49%" background="{url}/themes/Orange/bottom.gif" style="border-bottom: 1 solid #000000"> 
      <p align="right"><font face="Verdana" size="1" color="#FFFFFF"></font><font face="Verdana, Arial, Helvetica, sans-serif" size="1" color="#000000">{comments}</font></p>
    </td>
    <td width="49%" background="{url}/themes/Orange/bottom.gif" style="border-bottom: 1 solid #000000">
      <div align="right"><font face="Verdana" size="1" color="#FFFFFF"><b>Time: 
        {posttime}<br>
        Date: {postdate}</b></font></div>
    </td>
    <center>
      <td width="1%" valign="bottom" align="right" background="{url}/themes/Orange/leftb.gif"><img border="0" src="{url}/themes/Orange/botright.gif"></td>
    </center>
  </tr>
</table>
    <br><br>
