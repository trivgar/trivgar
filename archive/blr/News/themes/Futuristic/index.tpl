
<STYLE>BODY {
	MARGIN-TOP: 10px; MARGIN-BOTTOM: 0px
}
TD {
	FONT: 12px arial; COLOR: #444444
}

A {
	COLOR: #000000
}
A:visited {
	COLOR: #000000
}
A:hover {
	COLOR: #cccccc
}
.smallform {
	BORDER-RIGHT: #c7ccdc 1px solid; BORDER-TOP: #c7ccdc 1px solid; FONT-SIZE: 9pt; BORDER-LEFT: #c7ccdc 1px solid; BORDER-BOTTOM: #c7ccdc 1px solid; BACKGROUND-COLOR: #f0f1f6
}
DIV.compbox {
	PADDING-RIGHT: 22px; PADDING-LEFT: 30px; PADDING-BOTTOM: 5px; COLOR: #888888; PADDING-TOP: 5px; TEXT-ALIGN: right
}
DIV.menubox {
	PADDING-TOP: 23px
}
DIV.bodybox {
	PADDING-RIGHT: 20px; PADDING-LEFT: 18px; PADDING-TOP: 20px
}
DIV.textbox {
	PADDING-RIGHT: 40px; PADDING-LEFT: 40px; PADDING-BOTTOM: 15px; LINE-HEIGHT: 20px; PADDING-TOP: 15px
}
DIV.header {
	FONT: bold 16px arial; COLOR: #888888
}
A.nou {
	TEXT-DECORATION: none
}
</STYLE>
  
<div align="center">
  <table border="0" cellspacing="0" cellpadding="0" width="400">
    <tr> 
      <td> 
        <table width="464" border="0" cellspacing="0" cellpadding="0" background="{url}/themes/Futuristic/view_bg.jpg">
          <tr> 
            <td height="32">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;{subject}</td>
          </tr>
        </table>
        
      <table cellspacing=1 cellpadding=10 width=464 align=center 
            bgcolor=#c7ccdc border=0>
        <tbody> 
        <tr align="left" valign="top"> 
          <td colspan="2" bgcolor=#ffffff><font face=arial 
                  color=#444444 size=2><font face=arial color=#444444 
                  size=2> 
            <p>{news}<br>
            </p>
            </font></font></td>
        </tr>
        <tr align="left" valign="top">
          <td colspan="2" bgcolor=#ffffff height="16">{comments}</td>
        </tr>
        </tbody> 
      </table>
<table width=464 align=center background="{url}/themes/Futuristic/bottm.jpg"><tr><td>&nbsp;</td></tr></table>

  <br>
</div>
</table>