
<table width="100%" border="0" cellspacing="1" cellpadding="3">
  <tr> 
	<td height="34" class="catrow" valign="middle" height="25" align="center"><span class="catrowtext">{MESSAGE_TITLE}</span></td>
  </tr>
  <tr> 
	<td class="row2" align="center"> 
	  <form action="{S_CONFIRM_ACTION}" method="POST">
		<span class="mediumtext"><br>
		{MESSAGE_TEXT}<br>
		<br>
		{S_HIDDEN_FIELDS} 
		<input type="submit" name="confirm" value="{L_YES}">
		&nbsp;&nbsp; 
		<input type="submit" name="cancel" value="{L_NO}">
		</span> 
	  </form>
	</td>
  </tr>
</table>